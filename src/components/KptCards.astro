---
// keep/problem/try 는 이미 렌더된 HTML 문자열(마크다운 → HTML) 또는 null
interface Props {
  keep?: string | null;
  problem?: string | null;
  try?: string | null;
}

const { keep, problem, try: tryHtml } = Astro.props;

const cards = [
  { label: 'KEEP', tone: 'keep', html: keep },
  { label: 'PROBLEM', tone: 'problem', html: problem },
  { label: 'TRY', tone: 'try', html: tryHtml },
] as const;
---

<div class="kpt-grid">
  {
    cards.map((c) => (
      <div class="kpt-card">
        <div class="kpt-head">
          <span class="kpt-dot" style={`background:var(--${c.tone})`} />
          <span class="kpt-name" style={`color:var(--${c.tone})`}>
            {c.label}
          </span>
        </div>
        {c.html ? (
          <div class="kpt-body" set:html={c.html} />
        ) : (
          <p class="kpt-empty">작성되지 않음</p>
        )}
      </div>
    ))
  }
</div>

<style>
  .kpt-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
    align-items: stretch;
  }
  .kpt-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 16px;
    display: flex;
    flex-direction: column;
  }
  .kpt-head {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-bottom: 10px;
  }
  .kpt-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
  }
  .kpt-name {
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.06em;
  }

  .kpt-body {
    font-size: 14px;
    line-height: 1.65;
    color: var(--text);
  }
  .kpt-empty {
    margin: 0;
    font-size: 14px;
    line-height: 1.65;
    color: var(--text-3);
  }

  /* 카드 내부 마크다운 요소 */
  .kpt-body :global(p) {
    margin: 0 0 8px;
  }
  .kpt-body :global(p:last-child) {
    margin-bottom: 0;
  }
  .kpt-body :global(ul),
  .kpt-body :global(ol) {
    margin: 0;
    padding-left: 18px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .kpt-body :global(li) {
    padding-left: 2px;
  }
  .kpt-body :global(li::marker) {
    color: var(--text-3);
  }
  .kpt-body :global(a) {
    color: var(--accent-strong);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .kpt-body :global(code) {
    background: var(--surface-2);
    padding: 2px 6px;
    border-radius: 5px;
    font-size: 0.9em;
  }
  .kpt-body :global(strong) {
    font-weight: 700;
  }

  @media (max-width: 720px) {
    .kpt-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
