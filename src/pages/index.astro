---
import { getCollection } from 'astro:content';
import WikiLayout from '../layouts/WikiLayout.astro';

// STEP 4 확인용 — 레이아웃 셸 검증. STEP 5에서 1a 홈 콘텐츠로 채웁니다.
const retros = (await getCollection('retros'))
  .filter((r) => !r.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<WikiLayout title="회고 위키">
  <h1 style="margin:0;font-size:25px;font-weight:800;letter-spacing:-.02em">회고 위키</h1>
  <p style="margin:8px 0 0;font-size:14px;color:var(--text-2)">매일의 Keep · Problem · Try 기록</p>
  <p style="margin-top:20px;color:var(--text-3);font-size:13px">
    (레이아웃 셸 확인용 — 회고 {retros.length}개 · STEP 5에서 홈 콘텐츠 구현)
  </p>
</WikiLayout>
