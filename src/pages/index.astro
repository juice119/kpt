---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

// STEP 3 확인용 임시 페이지 — STEP 5에서 1a 디자인으로 교체됩니다.
const retros = (await getCollection('retros'))
  .filter((r) => !r.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="회고 위키 (테마 확인)">
  <main style="max-width:760px;margin:0 auto;padding:40px 24px">
    <div style="display:flex;align-items:center;justify-content:space-between;gap:16px">
      <h1 style="margin:0;font-size:25px;font-weight:800;letter-spacing:-.02em">회고 위키</h1>
      <button
        id="themeToggle"
        style="border:1px solid var(--border);background:var(--surface);color:var(--text);border-radius:9px;padding:9px 14px;font:inherit;font-size:12.5px;font-weight:600;cursor:pointer"
        >테마 전환</button
      >
    </div>
    <p style="color:var(--text-2)">매일의 Keep · Problem · Try 기록 — 토큰/다크모드 확인용</p>

    <div style="display:flex;gap:8px;margin:18px 0">
      <span style="color:var(--keep);background:var(--keep-soft);padding:4px 12px;border-radius:20px;font-size:12px;font-weight:700">KEEP</span>
      <span style="color:var(--problem);background:var(--problem-soft);padding:4px 12px;border-radius:20px;font-size:12px;font-weight:700">PROBLEM</span>
      <span style="color:var(--try);background:var(--try-soft);padding:4px 12px;border-radius:20px;font-size:12px;font-weight:700">TRY</span>
    </div>

    <div style="background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:18px;box-shadow:var(--shadow)">
      <div style="font-size:11px;font-weight:700;color:var(--text-3);margin-bottom:8px">최근 회고 {retros.length}개</div>
      <ul style="margin:0;padding-left:18px;color:var(--text-2);line-height:1.9">
        {retros.map((r) => <li>{r.data.date.toISOString().slice(0, 10)} — {r.data.title ?? '(제목 없음)'}</li>)}
      </ul>
    </div>
  </main>

  <script is:inline>
    document.getElementById('themeToggle')?.addEventListener('click', () => window.__toggleTheme());
  </script>
</BaseLayout>
